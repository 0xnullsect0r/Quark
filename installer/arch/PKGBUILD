# Maintainer: Quark Contributors <https://github.com/0xnullsect0r/Quark>
pkgname=quark-bin
pkgver=0  # replaced at build time by pkgver()
pkgrel=1
pkgdesc="Train and run your own Llama 4-style MoE coding LLM on your own hardware"
arch=('x86_64')
url="https://github.com/0xnullsect0r/Quark"
license=('MIT')
depends=('gtk3' 'openssl' 'hicolor-icon-theme')
makedepends=('curl')
optdepends=(
  'cuda: NVIDIA GPU acceleration'
)
provides=('quark' 'quark-chat' 'quark-code')
conflicts=('quark')
options=('!strip')  # pre-stripped release binary

# GitHub's /releases/latest/download/ always redirects to the newest release asset.
source_x86_64=(
  "quark::https://github.com/0xnullsect0r/Quark/releases/latest/download/quark-linux-amd64"
  "quark-chat::https://github.com/0xnullsect0r/Quark/releases/latest/download/quark-chat-linux-amd64"
  "quark-code::https://github.com/0xnullsect0r/Quark/releases/latest/download/quark-code-linux-amd64"
)
sha256sums_x86_64=('SKIP' 'SKIP' 'SKIP')

# Resolve the version from the GitHub redirect (no API token needed).
pkgver() {
  curl -sI "https://github.com/0xnullsect0r/Quark/releases/latest" \
    | grep -i "^location:" \
    | sed 's|.*/v||; s/[[:space:]]//g; s/\r//'
}

package() {
  cd "$srcdir"

  # Binaries
  install -Dm755 quark      "${pkgdir}/usr/bin/quark"
  install -Dm755 quark-chat "${pkgdir}/usr/bin/quark-chat"
  install -Dm755 quark-code "${pkgdir}/usr/bin/quark-code"

  # Desktop entry
  install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/quark.desktop" << 'DESKTOP'
[Desktop Entry]
Version=1.0
Type=Application
Name=Quark LLM
GenericName=LLM Trainer
Comment=Train and run your own Llama 4-style MoE coding LLM
Exec=quark %u
Icon=quark
Terminal=false
Categories=Development;Science;ArtificialIntelligence;
Keywords=llm;ai;ml;training;coding;transformer;
StartupNotify=true
DESKTOP

  # License
  install -Dm644 /dev/stdin "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'MIT'
MIT License — Copyright (c) 2025 Quark Contributors
See https://github.com/0xnullsect0r/Quark/blob/main/LICENSE
MIT
}
