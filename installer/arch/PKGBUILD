# Maintainer: Quark Contributors <https://github.com/0xnullsect0r/Quark>
pkgname=quark-git
pkgver=1.0.14.r0.ga20f373  # replaced at build time by pkgver()
pkgrel=1
pkgdesc="Train and run your own Llama 4-style MoE coding LLM on your own hardware"
arch=('x86_64')
url="https://github.com/0xnullsect0r/Quark"
license=('MIT')
depends=('gtk3' 'openssl' 'hicolor-icon-theme')
makedepends=('git' 'rust' 'cargo')
optdepends=(
  'cuda: NVIDIA GPU acceleration'
)
provides=('quark' 'quark-chat' 'quark-code')
conflicts=('quark' 'quark-bin')
# Disable LTO for this package: ring 0.17's hand-written C/ASM sources are
# compiled by the `cc` crate inside ring's build.rs and MUST be plain objects.
# Arch's system LTO option injects -flto=auto into CFLAGS which causes the
# ring native archive to contain LTO bitcode — the linker then cannot resolve
# ring's assembly symbols at final link time.
options=('!lto')

source=("quark::git+https://github.com/0xnullsect0r/Quark.git")
sha256sums=('SKIP')

# Use the latest git tag as version; fall back to commit count + hash.
pkgver() {
  cd "$srcdir/quark"
  # If a vX.Y.Z tag exists on this commit, use it (strip the 'v' prefix).
  git describe --long --tags 2>/dev/null \
    | sed 's/^v//; s/\([^-]*-g\)/r\1/; s/-/./g' \
    || printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "$srcdir/quark"
  # ring 0.17 ships hand-written C/ASM that ring's build.rs compiles via the
  # `cc` crate.  If CFLAGS contain -flto (injected by Arch's system LTO even
  # after options=('!lto') as a safety net), the resulting objects are GCC LTO
  # bitcode which neither gcc nor rust-lld can resolve at final link time.
  # Strip any remaining -flto flags from the C/C++ compiler flags.
  export CFLAGS="$(echo "${CFLAGS:-}" | sed 's/-flto[^ ]*//g; s/  */ /g; s/^ //; s/ $//')"
  export CXXFLAGS="$(echo "${CXXFLAGS:-}" | sed 's/-flto[^ ]*//g; s/  */ /g; s/^ //; s/ $//')"
  # Disable Rust LTO explicitly.  We deliberately do NOT override the linker:
  # the default rust-lld can handle both the regular GCC objects produced by
  # ring's build.rs (now that -flto is stripped) and any LLVM-bitcode .rlib
  # files that may be cached from a previous build.  Forcing -C linker=gcc
  # causes gcc to fail on LLVM-bitcode .rlib files with "file format not
  # recognised".
  export RUSTFLAGS="-C lto=off"
  # Use the CPU backend; the cuda feature requires the CUDA toolkit at
  # build time (available on machines with an NVIDIA GPU + drivers).
  cargo build --release --workspace --features backend-cpu
}

package() {
  cd "$srcdir/quark"

  # Binaries
  install -Dm755 target/release/quark      "${pkgdir}/usr/bin/quark"
  install -Dm755 target/release/quark-chat "${pkgdir}/usr/bin/quark-chat"
  install -Dm755 target/release/quark-code "${pkgdir}/usr/bin/quark-code"

  # Desktop entry
  install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/quark.desktop" << 'DESKTOP'
[Desktop Entry]
Version=1.0
Type=Application
Name=Quark LLM
GenericName=LLM Trainer
Comment=Train and run your own Llama 4-style MoE coding LLM
Exec=quark %u
Icon=quark
Terminal=false
Categories=Development;Science;ArtificialIntelligence;
Keywords=llm;ai;ml;training;coding;transformer;
StartupNotify=true
DESKTOP

  # License
  if [[ -f LICENSE ]]; then
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  else
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE" << 'MIT'
MIT License — Copyright (c) 2025 Quark Contributors
See https://github.com/0xnullsect0r/Quark/blob/main/LICENSE
MIT
  fi
}
